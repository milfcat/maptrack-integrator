# Database (Neon PostgreSQL)
POSTGRES_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/integrator?sslmode=require

# Dashboard Auth (Basic Auth)
AUTH_USER=maptrack
AUTH_PASSWORD=your-password-here

# Vercel Cron Secret
CRON_SECRET=your-cron-secret-here

# Encryption Key (64 hex chars = 32 bytes for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string-here
